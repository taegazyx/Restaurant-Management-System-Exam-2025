      "name": "TC-004: ชำระเงินพอดียอด",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Change is 0\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    // ตรวจสอบว่ามีค่า change ตอบกลับมาและมีค่าเท่ากับ 0\r",
              "    pm.expect(jsonData.change).to.eql(0); \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
